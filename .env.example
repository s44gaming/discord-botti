# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:5000/callback

# Flask Web Dashboard
FLASK_SECRET_KEY=generate_a_random_secret_key
FLASK_ENV=development

# Optional: Base URL for OAuth callback (use your domain in production)
BASE_URL=http://localhost:5000

# Kehittäjäportaali: Discord-käyttäjä-ID:t pilkulla erotettuna (vain nämä näkevät /dev)
DEV_USER_IDS=123456789012345678,987654321098765432

# Botin tiedot (voi olla myös data/bot_info.txt tai salattu data/bot_info.enc)
BOT_DESCRIPTION=Monipalvelin-botti, hallinta: !hallinta
BOT_DEVELOPERS=S44Gaming
BOT_INVITE_LINK=https://discord.gg/ujB4JHfgcg
BOT_APPLY_URL=

# Muokkaussalasana botin tiedoille (kehittäjäportaali). Kopioi .env-tiedostoon – .env ei ole repossa, joten salasana ei näy.
BOT_INFO_EDIT_PASSWORD=xQ2#nL8$vKp5mRj9@wFz3bYc7!nHs6Ua4Jg0

# Tekijänoikeudet S44Gaming kaikki oikeudet pidätetään. https://discord.gg/ujB4JHfgcg
